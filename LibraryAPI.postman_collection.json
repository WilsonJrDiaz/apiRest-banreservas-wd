      "name": "1. Agregar un libro",
      "item": [
        {
          "name": "1a-1b-1c-1d - Agregar libro exitosamente (200 OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// a. Validar código de respuesta exitoso: 200 OK",
                  "pm.test('a. Status code es 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// b. Validar estructura del JSON: nombres de Key y tipo de valores",
                  "pm.test('b. Respuesta contiene key Msg de tipo string', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('Msg');",
                  "    pm.expect(json.Msg).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('b. Respuesta contiene key ID de tipo string', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('ID');",
                  "    pm.expect(json.ID).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('b. Mensaje de éxito es correcto', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.Msg).to.eql('successfully added');",
                  "});",
                  "",
                  "// c. Validar que el tiempo de respuesta sea inferior a 500 ms",
                  "pm.test('c. Tiempo de respuesta es menor a 500 ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "// d. Validar que el valor del campo ID sea la concatenación de isbn + aisle",
                  "pm.test('d. El campo ID es la concatenación de isbn + aisle', function () {",
                  "    var json = pm.response.json();",
                  "    var body = JSON.parse(pm.request.body.raw);",
                  "    var expectedId = body.isbn + body.aisle;",
                  "    pm.expect(json.ID).to.eql(expectedId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
